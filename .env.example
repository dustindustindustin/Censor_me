# Censor Me — Environment Configuration
# Copy to .env and adjust for your setup

# GPU acceleration for EasyOCR (true = enabled, false = CPU only)
# EasyOCR auto-detects CUDA; set to false to force CPU mode
OCR_USE_GPU=true

# ffmpeg binary path (leave empty to use system PATH)
FFMPEG_PATH=

# Directory for storing project files (defaults to ~/censor_me_projects)
PROJECTS_DIR=

# Directory for storing temporary proxy files (defaults to {project_dir}/.proxy)
PROXY_DIR=

# OCR sampling rate: analyze 1 frame every N frames (default: 5 at 30fps = 6fps OCR)
OCR_SAMPLE_INTERVAL=5

# Proxy video resolution (480, 720, 1080)
PROXY_RESOLUTION=720

# Development mode: enables hot-reload and extra logging
DEV_MODE=false

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
